+// Constrains the camera's center coordinate to a region, so the user cannot
+// pan the map outside of it (MKMapView.cameraBoundary, iOS 13+). Passed a
+// coordinate region dict {latitude, longitude, latitudeDelta, longitudeDelta}.
+// A nil/incomplete dict removes the boundary.
+- (void)setCameraBoundary:(NSDictionary *)cameraBoundary {
+    if (!@available(iOS 13.0, *)) {
+        return;
+    }
+
+    NSNumber *latitude = cameraBoundary[@"latitude"];
+    NSNumber *longitude = cameraBoundary[@"longitude"];
+    NSNumber *latitudeDelta = cameraBoundary[@"latitudeDelta"];
+    NSNumber *longitudeDelta = cameraBoundary[@"longitudeDelta"];
+
+    if (latitude == nil || longitude == nil ||
+        latitudeDelta == nil || longitudeDelta == nil) {
+        [super setCameraBoundary:nil animated:NO];
+        return;
+    }
+
+    MKCoordinateRegion region = MKCoordinateRegionMake(
+        CLLocationCoordinate2DMake([latitude doubleValue], [longitude doubleValue]),
+        MKCoordinateSpanMake([latitudeDelta doubleValue], [longitudeDelta doubleValue]));
+
+    MKMapCameraBoundary *boundary =
+        [[MKMapCameraBoundary alloc] initWithCoordinateRegion:region];
+
+    BOOL animated = [cameraBoundary[@"animated"] boolValue];
+    [super setCameraBoundary:boundary animated:animated];
+}
